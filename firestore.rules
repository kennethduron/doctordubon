rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function hasProfile() {
      return signedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function role() {
      return hasProfile() ? userDoc().data.role : null;
    }

    function clinicId() {
      return hasProfile() ? userDoc().data.clinicId : null;
    }

    function activeUser() {
      return hasProfile() && userDoc().data.status == 'active';
    }

    function technicalOwner() {
      return activeUser() && role() == 'technical_owner';
    }

    function businessOwner() {
      return activeUser() && role() == 'business_owner';
    }

    function admin() {
      return activeUser() && role() == 'admin';
    }

    function canManageUsers() {
      return technicalOwner() || businessOwner();
    }

    function canReadUserResource() {
      return activeUser()
        && resource.data.clinicId == clinicId()
        && (
          technicalOwner()
          || (businessOwner() && resource.data.role == 'admin')
        );
    }

    function canManageClinic() {
      return technicalOwner() || businessOwner();
    }

    function canCreateMovement() {
      return technicalOwner() || businessOwner() || admin();
    }

    function canEditMovement() {
      return technicalOwner() || businessOwner();
    }

    function sameClinicResource() {
      return activeUser() && resource.data.clinicId == clinicId();
    }

    function sameClinicRequest() {
      return activeUser() && request.resource.data.clinicId == clinicId();
    }

    function validRole(value) {
      return value in ['technical_owner', 'business_owner', 'admin'];
    }

    function validUserStatus(value) {
      return value in ['active', 'pending', 'disabled'];
    }

    function validMovementRecord(data) {
      return data.keys().hasAll([
          'id', 'clinicId', 'type', 'category', 'paymentMethod', 'amount',
          'description', 'date', 'status', 'createdBy', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasOnly([
          'id', 'clinicId', 'type', 'category', 'paymentMethod', 'amount',
          'description', 'notes', 'date', 'status', 'createdBy', 'createdByName',
          'createdAt', 'updatedAt', 'updatedBy', 'deletedAt', 'deletedBy'
        ])
        && data.id is string
        && data.clinicId is string
        && data.type in ['income', 'expense']
        && data.category is string
        && data.paymentMethod in ['efectivo', 'transferencia', 'tarjeta', 'otro']
        && data.amount is number
        && data.amount > 0
        && data.description is string
        && (!('notes' in data) || data.notes is string)
        && data.date is string
        && data.status in ['active', 'edited', 'deleted']
        && data.createdBy is string;
    }

    function validNewMovement(data, movementId) {
      return validMovementRecord(data)
        && data.keys().hasOnly([
          'id', 'clinicId', 'type', 'category', 'paymentMethod', 'amount',
          'description', 'notes', 'date', 'status', 'createdBy', 'createdByName',
          'createdAt', 'updatedAt'
        ])
        && data.id == movementId
        && data.status == 'active'
        && data.createdBy == request.auth.uid
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function validClinicRecord(data) {
      return data.keys().hasAll([
          'clinicName', 'doctorName', 'email', 'phone', 'currency',
          'appUrl', 'updatedAt', 'updatedBy'
        ])
        && data.keys().hasOnly([
          'clinicName', 'doctorName', 'email', 'phone', 'currency',
          'appUrl', 'updatedAt', 'updatedBy'
        ])
        && data.clinicName is string
        && data.doctorName is string
        && data.email is string
        && data.phone is string
        && data.currency == 'HNL'
        && data.appUrl is string
        && data.updatedBy == request.auth.uid
        && data.updatedAt == request.time;
    }
    function validNotificationType(value) {
      return value in [
        'access_request', 'user_approved', 'income_created', 'expense_created',
        'movement_deleted', 'daily_review', 'system'
      ];
    }

    function validNotificationSeverity(value) {
      return value in ['info', 'success', 'warning', 'danger'];
    }

    function validNotificationAudience(value) {
      return value in ['technical_owner', 'business_owner', 'admin', 'user', 'responsibles', 'all'];
    }

    function validOptionalRole(value) {
      return value == '' || validRole(value);
    }

    function validNotificationRoleList(value) {
      return value is list && value.hasOnly(['technical_owner', 'business_owner', 'admin']);
    }

    function validStringList(value) {
      return value is list;
    }

    function notificationAvoidsTechnicalOwner(data) {
      return data.actorRole != 'technical_owner'
        && data.recipientUserRole != 'technical_owner'
        && data.relatedUserRole != 'technical_owner';
    }

    function canReadNotificationResource() {
      return activeUser()
        && resource.data.clinicId == clinicId()
        && (
          technicalOwner()
          || (
            notificationAvoidsTechnicalOwner(resource.data)
            && (
              resource.data.visibleToRoles.hasAny([role()])
              || resource.data.visibleToUserIds.hasAny([request.auth.uid])
            )
          )
        );
    }

    function validNotificationRecord(data, notificationId) {
      return data.keys().hasAll([
          'id', 'clinicId', 'title', 'message', 'type', 'severity', 'audience',
          'recipientUserId', 'actorUserId', 'actorRole', 'recipientUserRole',
          'relatedUserId', 'relatedUserRole', 'relatedMovementId', 'visibleToRoles',
          'visibleToUserIds', 'readBy', 'createdAt', 'updatedAt'
        ])
        && data.keys().hasOnly([
          'id', 'clinicId', 'title', 'message', 'type', 'severity', 'audience',
          'recipientUserId', 'actorUserId', 'actorRole', 'recipientUserRole',
          'relatedUserId', 'relatedUserRole', 'relatedMovementId', 'visibleToRoles',
          'visibleToUserIds', 'readBy', 'createdAt', 'updatedAt'
        ])
        && data.id == notificationId
        && data.clinicId == 'clinic_dr_oscar_dubon'
        && data.title is string
        && data.message is string
        && data.title.size() > 0
        && data.title.size() <= 80
        && data.message.size() > 0
        && data.message.size() <= 240
        && validNotificationType(data.type)
        && validNotificationSeverity(data.severity)
        && validNotificationAudience(data.audience)
        && data.recipientUserId is string
        && data.actorUserId is string
        && validOptionalRole(data.actorRole)
        && validOptionalRole(data.recipientUserRole)
        && data.relatedUserId is string
        && validOptionalRole(data.relatedUserRole)
        && data.relatedMovementId is string
        && validNotificationRoleList(data.visibleToRoles)
        && validStringList(data.visibleToUserIds)
        && validStringList(data.readBy)
        && data.readBy.size() == 0
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    function exactResponsibleAudience(data) {
      return data.audience == 'responsibles'
        && data.visibleToRoles.size() == 2
        && data.visibleToRoles.hasAll(['technical_owner', 'business_owner'])
        && data.visibleToUserIds.size() == 0
        && data.recipientUserId == '';
    }

    function exactTechnicalAudience(data) {
      return data.audience == 'technical_owner'
        && data.visibleToRoles.size() == 1
        && data.visibleToRoles.hasAll(['technical_owner'])
        && data.visibleToUserIds.size() == 0
        && data.recipientUserId == '';
    }

    function canCreateAccessRequestNotification(data) {
      return signedIn()
        && data.type == 'access_request'
        && exactResponsibleAudience(data)
        && data.actorUserId == request.auth.uid
        && data.actorRole == 'admin'
        && data.relatedUserId == request.auth.uid
        && data.relatedUserRole == 'admin'
        && data.relatedMovementId == '';
    }

    function canCreateUserStatusNotification(data) {
      return canManageUsers()
        && data.type in ['user_approved', 'system']
        && data.audience == 'user'
        && data.actorUserId == ''
        && data.actorRole == ''
        && data.relatedMovementId == ''
        && data.recipientUserId != ''
        && data.relatedUserId == data.recipientUserId
        && data.visibleToRoles.size() == 0
        && data.visibleToUserIds.size() == 1
        && data.visibleToUserIds.hasAll([data.recipientUserId])
        && exists(/databases/$(database)/documents/users/$(data.recipientUserId))
        && get(/databases/$(database)/documents/users/$(data.recipientUserId)).data.clinicId == clinicId()
        && get(/databases/$(database)/documents/users/$(data.recipientUserId)).data.status == 'active'
        && get(/databases/$(database)/documents/users/$(data.recipientUserId)).data.role != 'technical_owner'
        && (
          technicalOwner()
          || get(/databases/$(database)/documents/users/$(data.recipientUserId)).data.role == 'admin'
        );
    }

    function canCreateUserDisabledNotification(data) {
      return canManageUsers()
        && data.type == 'system'
        && (exactResponsibleAudience(data) || exactTechnicalAudience(data))
        && data.actorUserId == ''
        && data.actorRole == ''
        && data.recipientUserRole == ''
        && data.recipientUserId == ''
        && data.relatedUserId != ''
        && data.relatedUserRole != 'technical_owner'
        && data.relatedMovementId == ''
        && exists(/databases/$(database)/documents/users/$(data.relatedUserId))
        && get(/databases/$(database)/documents/users/$(data.relatedUserId)).data.clinicId == clinicId()
        && get(/databases/$(database)/documents/users/$(data.relatedUserId)).data.status == 'disabled'
        && get(/databases/$(database)/documents/users/$(data.relatedUserId)).data.role == data.relatedUserRole
        && (
          technicalOwner()
          || get(/databases/$(database)/documents/users/$(data.relatedUserId)).data.role == 'admin'
        );
    }

    function canCreateMovementNotification(data) {
      return canCreateMovement()
        && data.type in ['income_created', 'expense_created', 'movement_deleted']
        && exactResponsibleAudience(data)
        && data.actorUserId == ''
        && data.actorRole == ''
        && data.recipientUserRole == ''
        && data.relatedUserId == ''
        && data.relatedUserRole == ''
        && data.relatedMovementId != '';
    }

    match /notifications/{notificationId} {
      allow read: if canReadNotificationResource();
      allow create: if validNotificationRecord(request.resource.data, notificationId)
        && request.resource.data.clinicId == clinicId()
        && (
          canCreateAccessRequestNotification(request.resource.data)
          || canCreateUserStatusNotification(request.resource.data)
          || canCreateUserDisabledNotification(request.resource.data)
          || canCreateMovementNotification(request.resource.data)
        );
      allow update: if canReadNotificationResource()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['readBy', 'updatedAt'])
        && request.resource.data.updatedAt == request.time
        && request.resource.data.readBy is list
        && request.resource.data.readBy.hasAll(resource.data.readBy)
        && request.auth.uid in request.resource.data.readBy
        && (
          (
            !(request.auth.uid in resource.data.readBy)
            && request.resource.data.readBy.size() == resource.data.readBy.size() + 1
          )
          || (
            request.auth.uid in resource.data.readBy
            && request.resource.data.readBy.size() == resource.data.readBy.size()
          )
        );
      allow delete: if false;
    }
    match /users/{userId} {
      // Pending y disabled solo pueden leer su propio perfil. El Técnico consulta
      // la clínica completa; el Dueño solo su perfil y cuentas de Administrador.
      allow get: if signedIn() && (
        request.auth.uid == userId
        || canReadUserResource()
      );
      allow list: if canReadUserResource();

      allow create: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.keys().hasAll([
          'id', 'clinicId', 'name', 'username', 'email', 'role', 'status', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.keys().hasOnly([
          'id', 'clinicId', 'name', 'username', 'email', 'role', 'status', 'createdAt', 'updatedAt'
        ])
        && request.resource.data.id == userId
        && request.resource.data.clinicId == 'clinic_dr_oscar_dubon'
        && request.resource.data.name is string
        && request.resource.data.username is string
        && request.resource.data.username.matches('^[a-z0-9._-]{3,30}$')
        && request.resource.data.email is string
        && request.resource.data.role == 'admin'
        && request.resource.data.status == 'pending'
        && request.resource.data.createdAt == request.time
        && request.resource.data.updatedAt == request.time;

      // El Dueño operativo solo puede aprobar, deshabilitar o habilitar administradores.
      allow update: if businessOwner()
        && resource.data.clinicId == clinicId()
        && request.resource.data.clinicId == resource.data.clinicId
        && resource.data.role == 'admin'
        && request.resource.data.role == 'admin'
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'updatedAt'])
        && request.resource.data.updatedAt == request.time
        && (
          (resource.data.status == 'pending' && request.resource.data.status == 'active')
          || (resource.data.status == 'active' && request.resource.data.status == 'disabled')
          || (resource.data.status == 'disabled' && request.resource.data.status == 'active')
        );

      // Un Técnico puede gestionar roles y estados de su clínica. Si se gestiona
      // a sí mismo debe conservar rol Técnico y estado activo; así siempre queda
      // al menos el Técnico que autoriza la operación.
      allow update: if technicalOwner()
        && resource.data.clinicId == clinicId()
        && request.resource.data.clinicId == resource.data.clinicId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'status', 'updatedAt'])
        && validRole(request.resource.data.role)
        && validUserStatus(request.resource.data.status)
        && request.resource.data.updatedAt == request.time
        && (
          request.auth.uid != userId
          || (
            request.resource.data.role == 'technical_owner'
            && request.resource.data.status == 'active'
          )
        );

      allow delete: if false;
    }

    match /movements/{movementId} {
      allow read: if sameClinicResource();
      allow create: if canCreateMovement()
        && sameClinicRequest()
        && validNewMovement(request.resource.data, movementId);

      // Edición normal: solo responsables operativos, campos financieros
      // controlados y metadatos inmutables.
      allow update: if sameClinicResource()
        && canEditMovement()
        && resource.data.status in ['active', 'edited']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'type', 'category', 'paymentMethod', 'amount', 'description', 'notes',
          'date', 'status', 'updatedAt', 'updatedBy'
        ])
        && request.resource.data.status == 'edited'
        && request.resource.data.updatedBy == request.auth.uid
        && request.resource.data.updatedAt == request.time
        && request.resource.data.clinicId == resource.data.clinicId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && validMovementRecord(request.resource.data);

      // Eliminación lógica: nunca borra el documento y solo cambia estado y
      // metadatos de auditoría.
      allow update: if sameClinicResource()
        && canEditMovement()
        && resource.data.status in ['active', 'edited']
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'status', 'deletedAt', 'deletedBy', 'updatedAt'
        ])
        && request.resource.data.status == 'deleted'
        && request.resource.data.deletedBy == request.auth.uid
        && request.resource.data.deletedAt == request.time
        && request.resource.data.updatedAt == request.time
        && request.resource.data.clinicId == resource.data.clinicId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && validMovementRecord(request.resource.data);

      allow delete: if false;
    }

    match /clinics/{clinicIdDocument} {
      allow read: if canManageClinic() && clinicIdDocument == clinicId();
      allow create, update: if canManageClinic()
        && clinicIdDocument == clinicId()
        && validClinicRecord(request.resource.data);
      allow delete: if false;
    }

    match /invitations/{invitationId} {
      allow read: if canManageUsers() && resource.data.clinicId == clinicId();
      allow create: if canManageUsers()
        && request.resource.data.clinicId is string
        && request.resource.data.clinicId == clinicId();
      allow update: if canManageUsers()
        && resource.data.clinicId == clinicId()
        && request.resource.data.clinicId == resource.data.clinicId;
      allow delete: if false;
    }
  }
}
